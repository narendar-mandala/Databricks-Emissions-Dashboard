   "source": [
    "SELECT\n",
    "  county_state_name,\n",
    "  SUM(TRY_CAST(REPLACE(`GHG emissions mtons CO2e`, ',', '') AS DOUBLE)) / SUM(population) AS emissions_per_person\n",
    "FROM\n",
    "  emissions_data\n",
    "GROUP BY\n",
    "  county_state_name\n",
    "ORDER BY\n",
    "  emissions_per_person DESC"
   ]
  }
 ],
