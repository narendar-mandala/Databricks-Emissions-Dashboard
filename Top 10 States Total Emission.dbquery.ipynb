   "source": [
    "SELECT\n",
    "  county_state_name,\n",
    "  population,\n",
    "  TRY_CAST(REPLACE(`GHG emissions mtons CO2e`, ',', '') AS DOUBLE)  AS Total_Emissions\n",
    "FROM\n",
    "  emissions_data\n",
    "ORDER BY\n",
    "  total_emissions DESC\n",
    "LIMIT 10"
   ]
